{
  "name": "ai-email-organizer",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "check": "pnpm -r --if-present run lint && pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "db:migrate": "pnpm --filter @aio/database run db:migrate",
    "db:status": "pnpm --filter @aio/database run db:status",
    "db:verify": "pnpm --filter @aio/database run db:verify",
    "build:runtime": "node scripts/build-runtime.mjs",
    "ops:summary": "tsx scripts/operations.ts summary",
    "ops:replay-queue": "tsx scripts/operations.ts replay-queue",
    "validate:gmail:dry-run": "tsx scripts/gmail-validation.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@aio/contracts": "workspace:*",
    "@aio/database": "workspace:*",
    "@aio/jobs": "workspace:*",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.3"
  }
}
